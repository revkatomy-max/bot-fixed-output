# ============================================
# DISCORD BOT PTPT - Environment Configuration
# ============================================

# Bot Token dari Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Client ID (Application ID) dari Discord Developer Portal
CLIENT_ID=your_client_id_here

# Guild ID (Server ID) untuk development (kosongkan untuk global commands)
GUILD_ID=your_guild_id_here

# ============================================
# CHANNEL IDs — SISTEM & LOG
# ============================================

# Channel untuk log transaksi
TRANSACTION_LOG_CHANNEL_ID=your_transaction_log_channel_id

# Channel untuk log ticket (transcript)
TICKET_LOG_CHANNEL_ID=your_ticket_log_channel_id

# Category ID untuk ticket channels
TICKET_CATEGORY_ID=your_ticket_category_id

# ============================================
# CHANNEL IDs — SLOT LIST GLOBAL (opsional)
# Untuk menampilkan semua slot aktif secara keseluruhan
# ============================================
SLOT_LIST_CHANNEL_1=id_channel_slot_list_1
SLOT_LIST_CHANNEL_2=id_channel_slot_list_2
SLOT_LIST_CHANNEL_3=id_channel_slot_list_3

# ============================================
# CHANNEL IDs — PER DURASI (WAJIB DIISI)
# Setiap durasi punya channel sendiri untuk menampilkan daftar order aktif.
# Isi dengan ID channel yang sudah dibuat di server Discord kamu.
# ============================================
# Channel notifikasi semua order masuk (1 channel untuk semua durasi)
ORDER_MASUK_CHANNEL_ID=1513368175033450637

DURATION_CHANNEL_6H=id_channel_untuk_6_jam
DURATION_CHANNEL_12H=id_channel_untuk_12_jam
DURATION_CHANNEL_24H=id_channel_untuk_24_jam
DURATION_CHANNEL_36H=id_channel_untuk_36_jam
DURATION_CHANNEL_48H=id_channel_untuk_48_jam
DURATION_CHANNEL_72H=id_channel_untuk_72_jam

# ============================================
# ROLE IDs
# ============================================
MODERATOR_ROLE_ID=your_moderator_role_id
ADMIN_ROLE_ID=your_admin_role_id

# ============================================
# KONFIGURASI BOT
# ============================================

# Cooldown create ticket (dalam detik)
TICKET_COOLDOWN=60

# Level log: error | warn | info | debug
LOG_LEVEL=info

# ============================================
# QRIS / PEMBAYARAN
# ============================================
QRIS_DATA=your_qris_payment_string_or_account_number
PAYMENT_NAME=Nama Penerima

# ============================================
# HARGA DEFAULT (dalam Rupiah, per slot)
# ============================================
DEFAULT_PRICE_6H=5000
DEFAULT_PRICE_12H=10000
DEFAULT_PRICE_24H=20000
DEFAULT_PRICE_36H=30000
DEFAULT_PRICE_48H=35000
DEFAULT_PRICE_72H=50000

# ============================================
# SLOT
# ============================================
# Maksimum total slot aktif di seluruh sistem
MAX_SLOTS=18
