# ============================================
# DISCORD BOT PTPT - Environment Configuration
# ============================================

# Bot Token dari Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Client ID (Application ID) dari Discord Developer Portal
CLIENT_ID=your_client_id_here

# Guild ID (Server ID) untuk development (kosongkan untuk global commands)
GUILD_ID=your_guild_id_here

# ============================================
# CHANNEL IDs
# ============================================

# Channel untuk log transaksi
TRANSACTION_LOG_CHANNEL_ID=your_transaction_log_channel_id

# Channel untuk log ticket (transcript)
TICKET_LOG_CHANNEL_ID=your_ticket_log_channel_id

# Category ID untuk ticket channels
TICKET_CATEGORY_ID=your_ticket_category_id

# ============================================
# ROLE IDs
# ============================================

# Role Moderator
MODERATOR_ROLE_ID=your_moderator_role_id

# Role Administrator
ADMIN_ROLE_ID=your_admin_role_id

# ============================================
# KONFIGURASI BOT
# ============================================

# Cooldown create ticket (dalam detik)
TICKET_COOLDOWN=60

# Prefix log
LOG_LEVEL=info

# ============================================
# QRIS / PEMBAYARAN
# ============================================

# Data QRIS untuk QR Code (nomor rekening / QRIS string)
QRIS_DATA=your_qris_payment_string_or_account_number

# Nama penerima pembayaran
PAYMENT_NAME=Nama Penerima

# ============================================
# HARGA DEFAULT (dalam Rupiah)
# ============================================
DEFAULT_PRICE_6H=5000
DEFAULT_PRICE_12H=10000
DEFAULT_PRICE_24H=20000
DEFAULT_PRICE_48H=35000
DEFAULT_PRICE_72H=50000
DEFAULT_PRICE_168H=100000

# Slot Configuration
MAX_SLOTS=18
SLOT_LIST_CHANNEL_ID=id_channel_list_slot
SLOT_LIST_CHANNEL_1=id_channel_slot_1
SLOT_LIST_CHANNEL_2=id_channel_slot_2
SLOT_LIST_CHANNEL_3=id_channel_slot_3
